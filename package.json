{
  "name": "scoreboard-app",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun x --bun vite dev",
    "build": "bun x --bun vite build && tsc --noEmit",
    "format": "biome check --write --unsafe",
    "check": "biome check && tsc --noEmit",
    "e2e": "playwright test --project=firefox",
    "e2e:chromium": "playwright test --project=chromium",
    "start": "bun run .output/server/index.mjs"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.36.2",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@fontsource-variable/newsreader": "^5.2.10",
    "@kobalte/core": "^0.13.11",
    "@nptr/contract-dsl": "workspace:*",
    "@tanstack/solid-query": "^5.100.5",
    "@tanstack/solid-query-devtools": "^5.100.5",
    "@tanstack/solid-router": "^1.168.24",
    "@tanstack/solid-router-devtools": "^1.166.13",
    "@tanstack/solid-router-ssr-query": "^1.166.12",
    "@tanstack/solid-start": "^1.167.47",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.15",
    "jose": "^6.2.2",
    "nitro": "^3.0.260415-beta",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "solid-icons": "^1.2.0",
    "solid-js": "^1.9.12",
    "uuid25": "^0.1.6",
    "uuidv7": "^1.2.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.0.1",
    "playwright": "^1.59.1",
    "@biomejs/biome": "^2.4.13",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.5.12",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.5"
  }
}
